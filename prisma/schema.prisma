// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// WagstaffMod companion dashboard models

model BotFavorite {
  id        String   @id @default(cuid())
  botId     String   // buster | brute | ballistic | butler
  userId    String   @default("anon") // future auth placeholder
  note      String?
  createdAt DateTime @default(now())

  @@unique([botId, userId])
}

model CalcHistory {
  id        String   @id @default(cuid())
  userId    String   @default("anon")
  botId     String
  tier      String   // MK1 | MK2 | MK3
  level     Int      @default(0)
  overcharge Boolean @default(false)
  result    Int      // computed damage
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  section   String   // hero | bots | calc | patches | config
  createdAt DateTime @default(now())
}
